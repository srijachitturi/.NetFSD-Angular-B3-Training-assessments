@model WebApplication3.Models.ContactInfo

<h2>Delete Contact</h2>
<hr />

<h4>Are you sure you want to delete this contact?</h4>
<br />

<dl class="row">
    <dt class="col-sm-3">Contact ID</dt>
    <dd class="col-sm-9">@Model.ContactId</dd>

    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.FirstName @Model.LastName</dd>

    <dt class="col-sm-3">Company</dt>
    <dd class="col-sm-9">@Model.CompanyName</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.EmailId</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="ContactId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="ShowContacts" class="btn btn-secondary">Cancel</a>
</form>
