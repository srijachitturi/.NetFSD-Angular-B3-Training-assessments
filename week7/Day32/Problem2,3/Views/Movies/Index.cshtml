@model IEnumerable<WebApplication4.Models.Movie>

@{
    ViewData["Title"] = "Movies List";
}

<h2>Movies List</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Movie</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Genre</th>
            <th>Release Date</th>
            <th>Price</th>
            <th>Rating</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Genre</td>
                <td>@(item.ReleaseDate.HasValue? item.ReleaseDate.Value.ToString("dd-MM-yyyy") : "")</td>
                <td>@(item.Price.HasValue? item.Price.Value.ToString("C") : "")</td>
                <td>@item.Rating</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>