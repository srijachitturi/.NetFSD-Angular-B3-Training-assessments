@using WebApplication2.Models
@model Product

<h1 class="display-5">Product Controller - Delete</h1>

@if (Model == null)
{
    <p>Requested Product Details are not available</p>
}
else
{
    <div>
        Product Id : @Model.ProductId <br />
        Product Name : @Model.ProductName <br />
        Price : @Model.Price <br />
        Category : @Model.Category <br />
    </div>
}

<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.ProductId" />
    <p>Do you want to delete this product details?</p>
    <button type="submit" class="btn btn-success">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>