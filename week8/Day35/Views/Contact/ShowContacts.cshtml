@model List<WebApplication6.Models.ContactInfo>

<h2>Contact List</h2>

<p>
    <a asp-action="AddContact" class="btn btn-primary">Add New Contact</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Contact Id</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email Id</th>
            <th>Mobile No</th>
            <th>Designation</th>
            <th>Company</th>
            <th>Department</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var contact in Model)
        {
            <tr>
                <td>@contact.ContactId</td>
                <td>@contact.FirstName</td>
                <td>@contact.LastName</td>
                <td>@contact.EmailId</td>
                <td>@contact.MobileNo</td>
                <td>@contact.Designation</td>
                <td>@contact.CompanyName</td>
                <td>@contact.DepartmentName</td>
                <td>
                    <a asp-action="GetContactById" asp-route-id="@contact.ContactId">Details</a> |
                    <a asp-action="EditContact" asp-route-id="@contact.ContactId">Edit</a> |
                    <a asp-action="DeleteContact" asp-route-id="@contact.ContactId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>